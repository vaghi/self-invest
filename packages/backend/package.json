{
  "name": "@self-invest/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:push": "dotenv -e ../../.env -- prisma db push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.3.1",
    "@self-invest/shared": "*",
    "cors": "^2.8.5",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "node-cron": "^3.0.3",
    "openai": "^4.85.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "technicalindicators": "^3.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.14",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
