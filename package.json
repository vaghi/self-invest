{
  "name": "self-invest",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/shared && concurrently \"npm run build -w packages/backend\" \"npm run build -w packages/frontend\"",
    "build:shared": "npm run build -w packages/shared",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:generate": "npm run db:generate -w packages/backend",
    "db:studio": "npm run db:studio -w packages/backend",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
